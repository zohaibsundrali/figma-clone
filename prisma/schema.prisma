generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  files     DesignFile[]
  members   WorkspaceMember[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  userEmail   String
  userName    String?
  role        String    @default("editor")
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model DesignFile {
  id          String           @id @default(cuid())
  title       String           @default("Untitled Design")
  ownerId     String
  canvasData  Json?
  isPublic    Boolean          @default(false)
  shareToken  String           @unique @default(cuid())
  thumbnail   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean          @default(false)
  isStarred   Boolean          @default(false)
  workspaceId String?
  // Public-link sharing controls
  shareRole         String    @default("viewer") // role granted by the public link: viewer | commenter | editor
  sharePasswordHash String? // bcrypt hash; null = no password
  shareExpiresAt    DateTime? // null = never expires
  comments    Comment[]
  members     FileMember[]
  workspace   Workspace?       @relation(fields: [workspaceId], references: [id])
  versions    VersionHistory[]

  @@index([ownerId])
  @@index([workspaceId])
  @@index([shareToken])
  @@index([updatedAt])
  @@index([isDeleted])
  @@index([isStarred])
  @@index([deletedAt])
  @@index([ownerId, isDeleted], map: "idx_designfile_deleted", where: raw("(\"isDeleted\" = true)"))
  @@index([ownerId], map: "idx_designfile_owner")
  @@index([ownerId, isStarred], map: "idx_designfile_starred", where: raw("(\"isStarred\" = true)"))
  @@index([ownerId, updatedAt], map: "idx_designfile_owner_updated")
  @@index([ownerId, isDeleted, deletedAt], map: "idx_designfile_deleted_at")
}

model Comment {
  id              String            @id @default(cuid())
  fileId          String
  authorId        String
  authorName      String
  authorAvatar    String?
  x               Float
  y               Float
  text            String
  shapeId         String?
  mentions        String[]          @default([])
  edited          Boolean           @default(false)
  resolved        Boolean           @default(false)
  parentCommentId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  file            DesignFile        @relation(fields: [fileId], references: [id], onDelete: Cascade)
  replies         Comment[]         @relation("CommentReplies")
  parentComment   Comment?          @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  reactions       CommentReaction[]
  notifications   Notification[]

  @@index([fileId])
  @@index([parentCommentId])
}

model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  userName  String
  emoji     String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  fileId    String
  commentId String?
  actorId   String
  actorName String
  message   String
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
  comment   Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId, type])
  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

model FileMember {
  id          String     @id @default(cuid())
  fileId      String
  email       String // lowercased invitee email
  userId      String? // Clerk id, populated once the invite is accepted / user known
  role        String     @default("viewer") // admin | editor | commenter | viewer
  status      String     @default("pending") // pending | accepted | expired | revoked
  invitedById String
  inviteToken String     @unique
  expiresAt   DateTime? // invitation expiry (not the same as link expiry)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  file        DesignFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, email])
  @@index([fileId])
  @@index([userId])
  @@index([inviteToken])
  @@index([email])
}

model ShareAuditLog {
  id        String   @id @default(cuid())
  fileId    String
  actorId   String
  actorName String?
  action    String // e.g. link_enabled, link_regenerated, password_set, invite_sent, role_changed, access_revoked
  target    String? // affected email / member id / token
  metadata  String? // small JSON blob of extra context
  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([createdAt])
}

model VersionHistory {
  id         String     @id @default(cuid())
  fileId     String
  authorId   String
  authorName String
  name       String
  canvasData Json
  createdAt  DateTime   @default(now())
  file       DesignFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
}

model Activity {
  id         String   @id @default(cuid())
  fileId     String
  authorId   String
  authorName String
  action     String
  details    String?
  createdAt  DateTime @default(now())

  @@index([fileId])
  @@index([createdAt])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  creatorId   String
  creatorName String
  canvasData  Json
  thumbnail   String?
  isPublic    Boolean  @default(false)
  category    String   @default("general")
  tags        String   @default("")
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([creatorId])
  @@index([isPublic])
  @@index([category])
  @@index([createdAt])
}

// One row per user (Clerk userId). Absence of a row, or status !== "active",
// means the user is effectively on the Free plan — see src/lib/subscription.ts.
model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 String    @default("free") // free | professional | organization
  status               String    @default("active") // active | pending_review | rejected | canceled | past_due
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  stripeSessionId      String?
  screenshotUrl        String? // base64 data URL, same pattern as DesignFile.thumbnail
  transactionNote      String?
  reviewedByEmail      String?
  reviewedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model Guide {
  id        String   @id @default(cuid())
  fileId    String
  setName   String
  position  Float
  type      String   @db.VarChar(10)
  locked    Boolean  @default(false)
  color     String   @default("#4f46e5")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fileId])
  @@index([setName])
  @@index([type])
}
